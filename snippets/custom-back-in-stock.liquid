{% comment %}
  custom-back-in-stock.liquid
  Formulaire d'alerte retour en stock — affiché quand une variante est épuisée
  Dawn 15.x · Vanilla JS · fetch /contact (Shopify forms)
  CSS : assets/custom-back-in-stock.css
  JS  : assets/custom-back-in-stock.js

  Accepte :
  - product     : {Object} produit Shopify (requis)
  - variant     : {Object} variante sélectionnée (optionnel — défaut : first_available)
  - accent_color: {String} couleur du bouton (optionnel)
{% endcomment %}

{%- liquid
  assign bis_variant = variant | default: product.selected_or_first_available_variant
  assign bis_accent  = accent_color | default: '#C9A96E'
  assign is_sold_out = true
  if bis_variant.available
    assign is_sold_out = false
  endif
-%}

{%- if is_sold_out -%}

{{ 'custom-back-in-stock.css' | asset_url | stylesheet_tag }}

<div
  class="cbis__wrap"
  data-cbis
  data-product-id="{{ product.id }}"
  data-variant-id="{{ bis_variant.id }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-title="{{ bis_variant.title | escape }}"
  style="--cbis-accent: {{ bis_accent }};"
>

  {%- comment %} ── État : formulaire ─────────────────────── {% endcomment %}
  <div class="cbis__form-wrap" data-cbis-form-wrap>

    <p class="cbis__intro">
      <span class="cbis__intro-icon" aria-hidden="true">🔔</span>
      Ce produit est actuellement épuisé.
      <strong>Soyez alerté(e) dès son retour&nbsp;!</strong>
    </p>

    <form class="cbis__form" data-cbis-form novalidate>
      <div class="cbis__input-row">
        <label class="cbis__label" for="cbis-email-{{ product.id }}">
          Votre adresse e-mail
        </label>
        <div class="cbis__input-wrap">
          <input
            type="email"
            id="cbis-email-{{ product.id }}"
            name="contact[email]"
            class="cbis__input"
            data-cbis-email
            placeholder="vous@exemple.com"
            autocomplete="email"
            required
            aria-required="true"
            aria-describedby="cbis-error-{{ product.id }}"
          >
          <button
            type="submit"
            class="cbis__submit"
            data-cbis-submit
          >
            <span class="cbis__submit-label">M'alerter</span>
            <span class="cbis__submit-spinner" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="2.2"
                  stroke-dasharray="22" stroke-dashoffset="8" stroke-linecap="round"/>
              </svg>
            </span>
          </button>
        </div>
        <p
          class="cbis__error"
          id="cbis-error-{{ product.id }}"
          data-cbis-error
          role="alert"
          aria-live="polite"
          hidden
        ></p>
      </div>

      {%- comment %} Champs cachés pour identifier le produit dans le message {% endcomment %}
      <input type="hidden" name="contact[body]"
        value="Alerte stock : {{ product.title | escape }} — {{ bis_variant.title | escape }} (ID variante : {{ bis_variant.id }})">
      <input type="hidden" name="contact[tags]" value="back-in-stock,{{ product.id }},{{ bis_variant.id }}">
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
    </form>

    <p class="cbis__privacy">
      <svg viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <rect x="2" y="6" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
        <path d="M5 6V4.5a2 2 0 0 1 4 0V6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      Vos données ne seront utilisées que pour cet envoi.
    </p>

  </div>

  {%- comment %} ── État : succès ─────────────────────────── {% endcomment %}
  <div class="cbis__success" data-cbis-success hidden>
    <span class="cbis__success-icon" aria-hidden="true">
      <svg viewBox="0 0 48 48" fill="none">
        <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2" opacity="0.2"/>
        <path d="M14 24L21 31L34 17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <p class="cbis__success-title">C'est noté !</p>
    <p class="cbis__success-msg">
      Nous vous préviendrons par e-mail dès que
      <strong>{{ product.title | escape }}</strong>
      {%- if bis_variant.title != 'Default Title' -%}
        &nbsp;({{ bis_variant.title | escape }})
      {%- endif -%}
      &nbsp;sera de nouveau disponible.
    </p>
  </div>

</div>

<script src="{{ 'custom-back-in-stock.js' | asset_url }}" defer></script>

{%- endif -%}
