{% comment %}
  custom-wishlist-button.liquid
  Bouton cœur wishlist — carte produit ou page produit

  Paramètres :
    product  {object}  obligatoire — objet produit Shopify
    variant  {string}  "card"    → positionné en absolu sur la carte (défaut)
                       "product" → inline avec label textuel

  Exemple carte produit (dans une boucle) :
    {%- render 'custom-wishlist-button', product: card_product -%}

  Exemple page produit :
    {%- render 'custom-wishlist-button', product: product, variant: 'product' -%}
{% endcomment %}

{%- liquid
  assign cwl_variant = variant | default: 'card'
-%}

<button
  class="cwl__btn cwl__btn--{{ cwl_variant }}"
  type="button"
  data-cwl-btn
  data-cwl-handle="{{ product.handle }}"
  aria-pressed="false"
  aria-label="Ajouter {{ product.title | escape }} à la liste de souhaits"
  {%- if cwl_variant == 'product' -%}
    data-cwl-label="Ajouter aux souhaits"
  {%- endif -%}
>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path
      class="cwl__heart-fill"
      d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
    />
    <path
      class="cwl__heart-stroke"
      fill="none"
      d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
    />
  </svg>
</button>
