{% comment %}
  custom-social-proof.liquid
  Notifications "preuve sociale" — toast bas-gauche
  Dawn 15.x · Vanilla JS · SessionStorage · Configurable via schema
{% endcomment %}

{%- if section.settings.enabled and section.blocks.size > 0 -%}

<link rel="stylesheet" href="{{ 'custom-social-proof.css' | asset_url }}" media="print" onload="this.media='all'">

<div
  class="csp__toast"
  data-social-proof
  aria-live="polite"
  aria-atomic="true"
  style="
    --csp-bg:      {{ section.settings.bg_color }};
    --csp-text:    {{ section.settings.text_color }};
    --csp-accent:  {{ section.settings.accent_color }};
    --csp-interval: {{ section.settings.rotation_interval | times: 1000 }};
  "
  hidden
>
  <button class="csp__close" data-csp-close aria-label="Fermer">
    <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
  </button>

  <div class="csp__icon" aria-hidden="true">
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="20" fill="var(--csp-accent)" opacity="0.15"/>
      <path d="M20 10C16.13 10 13 13.13 13 17C13 21.66 20 30 20 30C20 30 27 21.66 27 17C27 13.13 23.87 10 20 10ZM20 19.5C18.62 19.5 17.5 18.38 17.5 17C17.5 15.62 18.62 14.5 20 14.5C21.38 14.5 22.5 15.62 22.5 17C22.5 18.38 21.38 19.5 20 19.5Z" fill="var(--csp-accent)"/>
    </svg>
  </div>

  <div class="csp__body">
    <p class="csp__name" data-csp-name></p>
    <p class="csp__product" data-csp-product></p>
    <p class="csp__time" data-csp-time></p>
  </div>
</div>

<script type="application/json" data-csp-data>
  [
    {%- for block in section.blocks -%}
      {
        "name":    {{ block.settings.first_name | append: ' de ' | append: block.settings.city | json }},
        "product": {{ block.settings.product | json }},
        "time":    {{ block.settings.time_ago | json }}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>

<script src="{{ 'custom-social-proof.js' | asset_url }}" defer></script>

{%- endif -%}

{% schema %}
{
  "name": "Preuve sociale",
  "tag": "div",
  "class": "section-custom-social-proof",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Activer les notifications",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_interval",
      "label": "Intervalle entre les notifications (secondes)",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond du toast",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent (prénom, icône)",
      "default": "#C9A96E"
    }
  ],
  "blocks": [
    {
      "type": "notification",
      "name": "Notification",
      "settings": [
        {
          "type": "text",
          "id": "first_name",
          "label": "Prénom",
          "default": "Marie",
          "placeholder": "ex : Sophie"
        },
        {
          "type": "text",
          "id": "city",
          "label": "Ville",
          "default": "Paris",
          "placeholder": "ex : Lyon"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Produit acheté",
          "default": "vient d'acheter ce produit",
          "placeholder": "ex : Sérum éclat visage"
        },
        {
          "type": "text",
          "id": "time_ago",
          "label": "Temps écoulé",
          "default": "il y a 5 min",
          "placeholder": "ex : il y a 12 min"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Preuve sociale",
      "blocks": [
        {
          "type": "notification",
          "settings": {
            "first_name": "Marie",
            "city": "Paris",
            "product": "vient d'acheter ce produit",
            "time_ago": "il y a 5 min"
          }
        },
        {
          "type": "notification",
          "settings": {
            "first_name": "Sophie",
            "city": "Lyon",
            "product": "vient d'acheter ce produit",
            "time_ago": "il y a 12 min"
          }
        },
        {
          "type": "notification",
          "settings": {
            "first_name": "Camille",
            "city": "Bordeaux",
            "product": "vient d'acheter ce produit",
            "time_ago": "il y a 20 min"
          }
        }
      ]
    }
  ]
}
{% endschema %}
