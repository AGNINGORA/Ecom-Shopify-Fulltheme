{% comment %}
  custom-hero-banner.liquid
  Hero plein écran premium — image/vidéo, parallax, animations, overlay gradient,
  badge, focal point, trust icons, countdown, vidéo externe, filtres image
  Dawn 15.x · Vanilla JS
  CSS : assets/custom-hero-banner.css
{% endcomment %}

{{ 'custom-hero-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign img_desktop = section.settings.image_desktop
  assign img_mobile  = section.settings.image_mobile
  assign has_image   = false
  if img_desktop != blank
    assign has_image = true
  endif

  assign has_video = false
  if section.settings.content_type == 'video' and section.settings.video != blank
    assign has_video = true
  endif

  assign has_ext_video = false
  if section.settings.content_type == 'external_video' and section.settings.video_url != blank
    assign has_ext_video = true
  endif

  assign overlay_opacity_dec = section.settings.overlay_opacity | divided_by: 100.0
  assign overlay_type = section.settings.overlay_type

  assign txt_align = section.settings.text_alignment
  assign txt_pos   = section.settings.text_position
  assign anim      = section.settings.animation
  assign focal     = section.settings.focal_point
  assign content_w = section.settings.content_width

  assign cta_label = section.settings.cta_label
  assign cta_url   = section.settings.cta_url
  assign cta_style = section.settings.cta_style

  assign filter_brightness = section.settings.image_brightness | divided_by: 100.0
  assign filter_contrast   = section.settings.image_contrast | divided_by: 100.0
-%}

<section
  class="chb {% if anim != 'none' %}chb--animate{% endif %}"
  data-section-id="{{ section.id }}"
  data-chb-animation="{{ anim }}"
  {% if section.settings.enable_parallax and has_image %}data-chb-parallax{% endif %}
  style="
    --chb-height-desktop: {{ section.settings.height_desktop }}vh;
    --chb-height-mobile:  {{ section.settings.height_mobile }}vh;
    --chb-overlay:        {{ section.settings.overlay_color }};
    --chb-overlay-opacity:{{ overlay_opacity_dec }};
    --chb-overlay-end:    {{ section.settings.overlay_color_end | default: 'transparent' }};
    --chb-overlay-end-opacity: {{ section.settings.overlay_opacity_end | default: 0 | divided_by: 100.0 }};
    --chb-text:           {{ section.settings.text_color }};
    --chb-cta-bg:         {{ section.settings.cta_bg }};
    --chb-cta-txt:        {{ section.settings.cta_text_color }};
    --chb-cta-radius:     {{ section.settings.cta_radius }}px;
    --chb-focal:          {{ focal | replace: '-', ' ' }};
    --chb-brightness:     {{ filter_brightness }};
    --chb-contrast:       {{ filter_contrast }};
    --chb-text-shadow:    {{ section.settings.text_shadow_strength }};
    --chb-content-width:  {{ content_w }}rem;
    --chb-gap:            {{ section.settings.elements_gap }}rem;
    --chb-padding-top:    {{ section.settings.padding_top }}px;
    --chb-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  {{ section.shopify_attributes }}
>

  {%- comment %} ── Badge ──────────────────────────────────────── {% endcomment %}
  {%- if section.settings.badge_text != blank -%}
    <div class="chb__badge" style="background: {{ section.settings.badge_bg | default: '#C9A96E' }}; color: {{ section.settings.badge_color | default: '#fff' }};">
      {%- if section.settings.badge_icon != blank -%}
        <span class="chb__badge-icon" aria-hidden="true">{{ section.settings.badge_icon }}</span>
      {%- endif -%}
      {{ section.settings.badge_text | escape }}
    </div>
  {%- endif -%}

  {%- comment %} ── Media (image, vidéo, vidéo externe) ─────── {% endcomment %}
  <div class="chb__media" data-chb-media>

    {%- if has_video -%}
      <video
        class="chb__video"
        {% if section.settings.video_autoplay %}autoplay muted{% endif %}
        loop
        playsinline
        preload="metadata"
        poster="{{ section.settings.video.preview_image | image_url: width: 1920 }}"
      >
        {%- for source in section.settings.video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>

    {%- elsif has_ext_video -%}
      {%- assign vurl = section.settings.video_url -%}
      {%- if vurl contains 'youtube' or vurl contains 'youtu.be' -%}
        {%- comment %} YouTube {% endcomment %}
        {%- assign yt_id = vurl | split: 'v=' | last | split: '&' | first -%}
        {%- if vurl contains 'youtu.be' -%}
          {%- assign yt_id = vurl | split: 'youtu.be/' | last | split: '?' | first -%}
        {%- endif -%}
        <iframe
          class="chb__ext-video"
          src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="Vidéo hero"
        ></iframe>
      {%- elsif vurl contains 'vimeo' -%}
        {%- comment %} Vimeo {% endcomment %}
        {%- assign vim_id = vurl | split: 'vimeo.com/' | last | split: '/' | first | split: '?' | first -%}
        <iframe
          class="chb__ext-video"
          src="https://player.vimeo.com/video/{{ vim_id }}?autoplay=1&muted=1&loop=1&background=1"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="Vidéo hero"
        ></iframe>
      {%- endif -%}

    {%- elsif has_image -%}
      <picture>
        {%- if img_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ img_mobile | image_url: width: 375, format: 'webp' }} 375w,
              {{ img_mobile | image_url: width: 750, format: 'webp' }} 750w
            "
            width="{{ img_mobile.width }}"
            height="{{ img_mobile.height }}"
          >
        {%- elsif img_desktop != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ img_desktop | image_url: width: 375, format: 'webp' }} 375w,
              {{ img_desktop | image_url: width: 750, format: 'webp' }} 750w
            "
          >
        {%- endif -%}
        <img
          class="chb__img"
          data-chb-img
          src="{{ img_desktop | image_url: width: 1920, format: 'webp' }}"
          srcset="
            {{ img_desktop | image_url: width: 750, format: 'webp' }}  750w,
            {{ img_desktop | image_url: width: 1100, format: 'webp' }} 1100w,
            {{ img_desktop | image_url: width: 1500, format: 'webp' }} 1500w,
            {{ img_desktop | image_url: width: 1920, format: 'webp' }} 1920w
          "
          sizes="100vw"
          alt="{{ img_desktop.alt | default: section.settings.title | escape }}"
          width="{{ img_desktop.width }}"
          height="{{ img_desktop.height }}"
          loading="eager"
          fetchpriority="high"
          draggable="false"
        >
      </picture>

    {%- elsif request.design_mode -%}
      <div class="chb__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'chb__placeholder-svg' }}
      </div>
    {%- endif -%}

  </div>

  {%- comment %} ── Overlay ──────────────────────────────────── {% endcomment %}
  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="chb__overlay chb__overlay--{{ overlay_type }}" aria-hidden="true"></div>
  {%- endif -%}

  {%- comment %} ── Contenu texte ─────────────────────────────── {% endcomment %}
  <div class="chb__content chb__content--{{ txt_align }} chb__content--{{ txt_pos }}">
    <div class="page-width">
      <div class="chb__text" data-chb-text>

        {%- if section.settings.eyebrow != blank -%}
          <p class="chb__eyebrow chb__anim-el" data-chb-anim-delay="0">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <{{ section.settings.title_tag | default: 'h2' }} class="chb__title chb__title--{{ section.settings.title_size }} chb__anim-el" data-chb-anim-delay="1">
            {{ section.settings.title | newline_to_br }}
          </{{ section.settings.title_tag | default: 'h2' }}>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="chb__subtitle chb__anim-el" data-chb-anim-delay="2">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}

        {%- comment %} Countdown {% endcomment %}
        {%- if section.settings.countdown_date != blank -%}
          <div class="chb__countdown chb__anim-el" data-chb-anim-delay="3" data-chb-countdown="{{ section.settings.countdown_date }}">
            <div class="chb__cd-unit">
              <span class="chb__cd-num" data-chb-cd-d>00</span>
              <span class="chb__cd-label">Jours</span>
            </div>
            <span class="chb__cd-sep">:</span>
            <div class="chb__cd-unit">
              <span class="chb__cd-num" data-chb-cd-h>00</span>
              <span class="chb__cd-label">Heures</span>
            </div>
            <span class="chb__cd-sep">:</span>
            <div class="chb__cd-unit">
              <span class="chb__cd-num" data-chb-cd-m>00</span>
              <span class="chb__cd-label">Min</span>
            </div>
            <span class="chb__cd-sep">:</span>
            <div class="chb__cd-unit">
              <span class="chb__cd-num" data-chb-cd-s>00</span>
              <span class="chb__cd-label">Sec</span>
            </div>
          </div>
        {%- endif -%}

        {%- if cta_label != blank and cta_url != blank -%}
          <div class="chb__ctas chb__anim-el" data-chb-anim-delay="4">
            <a
              class="chb__cta chb__cta--{{ cta_style }}"
              href="{{ cta_url }}"
            >
              {%- if section.settings.cta_icon != blank -%}
                <span class="chb__cta-icon">{{ section.settings.cta_icon }}</span>
              {%- endif -%}
              {{ cta_label | escape }}
            </a>

            {%- if section.settings.cta2_label != blank and section.settings.cta2_url != blank -%}
              <a
                class="chb__cta chb__cta--{{ section.settings.cta2_style }}"
                href="{{ section.settings.cta2_url }}"
              >
                {{ section.settings.cta2_label | escape }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment %} Trust icons {% endcomment %}
        {%- if section.settings.show_trust_icons -%}
          <div class="chb__trust chb__anim-el" data-chb-anim-delay="5">
            {%- if section.settings.trust_1_text != blank -%}
              <div class="chb__trust-item">
                {%- if section.settings.trust_1_icon != blank -%}
                  <span class="chb__trust-icon">{{ section.settings.trust_1_icon }}</span>
                {%- endif -%}
                <span>{{ section.settings.trust_1_text | escape }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.trust_2_text != blank -%}
              <div class="chb__trust-item">
                {%- if section.settings.trust_2_icon != blank -%}
                  <span class="chb__trust-icon">{{ section.settings.trust_2_icon }}</span>
                {%- endif -%}
                <span>{{ section.settings.trust_2_text | escape }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.trust_3_text != blank -%}
              <div class="chb__trust-item">
                {%- if section.settings.trust_3_icon != blank -%}
                  <span class="chb__trust-icon">{{ section.settings.trust_3_icon }}</span>
                {%- endif -%}
                <span>{{ section.settings.trust_3_text | escape }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  {%- comment %} ── Flèche de défilement ───────────────────── {% endcomment %}
  {%- if section.settings.show_scroll_arrow -%}
    <div class="chb__scroll-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  {%- endif -%}

</section>

{%- comment %} ── JS : Parallax + Animations + Countdown ──────── {% endcomment %}
<script>
(function () {
  'use strict';

  var sectionEl = document.querySelector('.chb[data-section-id="{{ section.id }}"]');
  if (!sectionEl) return;

  // ── Parallax ──────────────────────────────────
  if (sectionEl.hasAttribute('data-chb-parallax')) {
    var media = sectionEl.querySelector('[data-chb-media]');
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (media && !prefersReduced) {
      var FACTOR = 0.3;
      var ticking = false;
      function updateParallax() {
        var rect = sectionEl.getBoundingClientRect();
        var vh = window.innerHeight;
        if (rect.bottom < 0 || rect.top > vh) { ticking = false; return; }
        var progress = -(rect.top / (vh + rect.height));
        var shift = progress * rect.height * FACTOR;
        media.style.transform = 'translateY(' + shift.toFixed(1) + 'px)';
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { window.requestAnimationFrame(updateParallax); ticking = true; }
      }, { passive: true });
      updateParallax();
    }
  }

  // ── Animations texte (IntersectionObserver) ───
  var animType = sectionEl.dataset.chbAnimation;
  if (animType && animType !== 'none') {
    var animEls = sectionEl.querySelectorAll('.chb__anim-el');
    if (animEls.length > 0 && 'IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animEls.forEach(function (el) {
              var delay = parseInt(el.dataset.chbAnimDelay || '0', 10);
              el.style.transitionDelay = (delay * 0.12) + 's';
              el.classList.add('chb__anim-el--visible');
            });
            observer.disconnect();
          }
        });
      }, { threshold: 0.15 });
      observer.observe(sectionEl);
    }
  }

  // ── Countdown ─────────────────────────────────
  var cdEl = sectionEl.querySelector('[data-chb-countdown]');
  if (cdEl) {
    var target = new Date(cdEl.dataset.chbCountdown).getTime();
    var dEl = cdEl.querySelector('[data-chb-cd-d]');
    var hEl = cdEl.querySelector('[data-chb-cd-h]');
    var mEl = cdEl.querySelector('[data-chb-cd-m]');
    var sEl = cdEl.querySelector('[data-chb-cd-s]');
    function updateCD() {
      var diff = Math.max(0, target - Date.now());
      if (diff === 0) { cdEl.textContent = 'Offre expirée'; return; }
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      if (dEl) dEl.textContent = String(d).padStart(2, '0');
      if (hEl) hEl.textContent = String(h).padStart(2, '0');
      if (mEl) mEl.textContent = String(m).padStart(2, '0');
      if (sEl) sEl.textContent = String(s).padStart(2, '0');
    }
    updateCD();
    setInterval(updateCD, 1000);
  }
})();
</script>

{% schema %}
{
  "name": "Hero Banner Pro",
  "tag": "div",
  "class": "section-custom-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "━━ MÉDIA ━━"
    },
    {
      "type": "select",
      "id": "content_type",
      "label": "Type de contenu",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Vidéo Shopify" },
        { "value": "external_video", "label": "YouTube / Vimeo" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image desktop"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile (optionnelle)",
      "info": "Si vide, l'image desktop est utilisée"
    },
    {
      "type": "select",
      "id": "focal_point",
      "label": "Point focal de l'image",
      "options": [
        { "value": "center-center", "label": "Centre" },
        { "value": "center-top",    "label": "Centre haut" },
        { "value": "center-bottom", "label": "Centre bas" },
        { "value": "left-center",   "label": "Gauche" },
        { "value": "right-center",  "label": "Droite" },
        { "value": "left-top",      "label": "Haut gauche" },
        { "value": "right-top",     "label": "Haut droite" },
        { "value": "left-bottom",   "label": "Bas gauche" },
        { "value": "right-bottom",  "label": "Bas droite" }
      ],
      "default": "center-center",
      "info": "Contrôle la zone visible quand l'image est recadrée"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Vidéo Shopify"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL YouTube ou Vimeo",
      "info": "Ex : https://www.youtube.com/watch?v=xxx"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Lecture automatique (muette)",
      "default": true
    },
    {
      "type": "header",
      "content": "━━ FILTRES IMAGE ━━"
    },
    {
      "type": "range",
      "id": "image_brightness",
      "label": "Luminosité",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_contrast",
      "label": "Contraste",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "━━ OVERLAY ━━"
    },
    {
      "type": "select",
      "id": "overlay_type",
      "label": "Type d'overlay",
      "options": [
        { "value": "solid",       "label": "Couleur unie" },
        { "value": "gradient-tb", "label": "Dégradé haut → bas" },
        { "value": "gradient-bt", "label": "Dégradé bas → haut" },
        { "value": "gradient-lr", "label": "Dégradé gauche → droite" },
        { "value": "gradient-rl", "label": "Dégradé droite → gauche" },
        { "value": "gradient-radial", "label": "Dégradé radial (centre clair)" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Couleur début",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacité début",
      "min": 0,
      "max": 95,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "color",
      "id": "overlay_color_end",
      "label": "Couleur fin (dégradés)",
      "default": "#000000",
      "info": "Utilisée uniquement avec les dégradés"
    },
    {
      "type": "range",
      "id": "overlay_opacity_end",
      "label": "Opacité fin (dégradés)",
      "min": 0,
      "max": 95,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "━━ DISPOSITION ━━"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur desktop",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Hauteur mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement horizontal",
      "options": [
        { "value": "left",   "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right",  "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Position verticale",
      "options": [
        { "value": "top",    "label": "Haut" },
        { "value": "middle", "label": "Milieu" },
        { "value": "bottom", "label": "Bas" }
      ],
      "default": "middle"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Largeur du contenu",
      "min": 40,
      "max": 90,
      "step": 5,
      "unit": "rem",
      "default": 72,
      "info": "Contrôle la largeur max du bloc texte"
    },
    {
      "type": "range",
      "id": "elements_gap",
      "label": "Espacement entre éléments",
      "min": 0.8,
      "max": 4.0,
      "step": 0.2,
      "unit": "rem",
      "default": 1.6
    },
    {
      "type": "header",
      "content": "━━ BADGE ━━"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "placeholder": "ex : Nouveauté",
      "info": "Laisser vide = pas de badge"
    },
    {
      "type": "text",
      "id": "badge_icon",
      "label": "Emoji badge",
      "placeholder": "ex : 🔥"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Fond du badge",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Texte du badge",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "━━ TEXTE ━━"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_shadow_strength",
      "label": "Ombre du texte",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0,
      "info": "0 = pas d'ombre, 10 = ombre forte. Améliore la lisibilité sur images claires."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche (au-dessus du titre)",
      "placeholder": "ex : Nouveauté · Collection Printemps"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre",
      "default": "Révélez votre beauté naturelle"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "Taille du titre",
      "options": [
        { "value": "sm", "label": "Petite" },
        { "value": "md", "label": "Moyenne" },
