{% comment %}
  custom-promo-bar.liquid
  Barre d'annonce rotative — sous le header ou dans header-group
  Dawn 15.x · Vanilla JS · Mobile-first
  CSS : assets/custom-promo-bar.css
  JS  : assets/custom-promo-bar.js
{% endcomment %}

{%- if section.settings.enabled and section.blocks.size > 0 -%}

{{ 'custom-promo-bar.css' | asset_url | stylesheet_tag }}

<div
  class="cpb__bar{% if section.settings.sticky %} cpb__bar--sticky{% endif %}"
  data-cpb
  style="
    --cpb-bg:      {{ section.settings.bg_color }};
    --cpb-text:    {{ section.settings.text_color }};
    --cpb-accent:  {{ section.settings.accent_color }};
    --cpb-speed:   {{ section.settings.rotation_speed | times: 1000 }}ms;
  "
  role="region"
  aria-label="Annonces"
>

  {%- comment %} ── Messages (un seul visible à la fois) ─── {% endcomment %}
  <div class="cpb__track" data-cpb-track aria-live="polite" aria-atomic="true">
    {%- for block in section.blocks -%}
      <div
        class="cpb__slide{% if forloop.first %} is-active{% endif %}"
        data-cpb-slide="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
        {% unless forloop.first %}aria-hidden="true"{% endunless %}
      >
        {%- if block.settings.icon != blank -%}
          <span class="cpb__icon" aria-hidden="true">{{ block.settings.icon }}</span>
        {%- endif -%}

        <span class="cpb__text">
          {%- if block.settings.link != blank -%}
            <a class="cpb__link" href="{{ block.settings.link }}">
              {{ block.settings.text | escape }}
            </a>
          {%- else -%}
            {{ block.settings.text | escape }}
          {%- endif -%}
        </span>
      </div>
    {%- endfor -%}
  </div>

  {%- comment %} ── Navigation (si > 1 bloc) ─────────────── {% endcomment %}
  {%- if section.blocks.size > 1 -%}
    <div class="cpb__nav" aria-label="Navigation des annonces">
      <button
        class="cpb__nav-btn cpb__nav-btn--prev"
        data-cpb-prev
        type="button"
        aria-label="Annonce précédente"
      >
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="cpb__dots" role="tablist" aria-label="Indicateurs">
        {%- for block in section.blocks -%}
          <button
            class="cpb__dot{% if forloop.first %} is-active{% endif %}"
            role="tab"
            data-cpb-dot="{{ forloop.index0 }}"
            aria-selected="{{ forloop.first | json }}"
            aria-label="Annonce {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>

      <button
        class="cpb__nav-btn cpb__nav-btn--next"
        data-cpb-next
        type="button"
        aria-label="Annonce suivante"
      >
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  {%- endif -%}

  {%- comment %} ── Bouton fermer ─────────────────────────── {% endcomment %}
  {%- if section.settings.dismissible -%}
    <button
      class="cpb__close"
      data-cpb-close
      type="button"
      aria-label="Fermer les annonces"
    >
      <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  {%- endif -%}

</div>

<script src="{{ 'custom-promo-bar.js' | asset_url }}" defer></script>

{%- endif -%}

{% schema %}
{
  "name": "Barre d'annonces",
  "tag": "div",
  "class": "cpb-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Activer la barre",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Coller sous le header (sticky)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Permettre la fermeture",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Vitesse de rotation (secondes)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (liens)",
      "default": "#C9A96E"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Annonce",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji / icône",
          "default": "🚚"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "default": "Livraison gratuite dès 50 € d'achat"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre d'annonces",
      "blocks": [
        { "type": "message", "settings": { "icon": "🚚", "text": "Livraison gratuite dès 50 € d'achat" } },
        { "type": "message", "settings": { "icon": "✨", "text": "Formules vegan & cruelty-free" } },
        { "type": "message", "settings": { "icon": "🎁", "text": "Un échantillon offert avec chaque commande" } }
      ]
    }
  ]
}
{% endschema %}
