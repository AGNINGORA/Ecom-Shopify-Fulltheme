{% comment %}
  custom-testimonials-carousel.liquid
  Grille masonry d'avis clients — images produit, étoiles, texte, auteur
  Dawn 15.x · CSS Grid · Mobile-first
  CSS : assets/custom-testimonials-carousel.css
{% endcomment %}

{{ 'custom-testimonials-carousel.css' | asset_url | stylesheet_tag }}

{%- assign testimonial_blocks = section.blocks | where: 'type', 'testimonial' -%}

<section
  class="ctc"
  data-section-id="{{ section.id }}"
  style="
    --ctc-accent:  {{ section.settings.accent_color }};
    --ctc-star:    {{ section.settings.star_color }};
    --ctc-card-bg: {{ section.settings.card_bg }};
    --ctc-text:    {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="ctc__inner page-width">

    {%- comment %} En-tête ─────────────────────────────────── {% endcomment %}
    <div class="ctc__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ctc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="ctc__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ctc__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment %} Grille masonry ──────────────────────────── {% endcomment %}
    {%- if testimonial_blocks.size > 0 -%}
      <div class="ctc__grid">
        {%- for block in testimonial_blocks -%}
          {%- liquid
            assign rating   = block.settings.rating | plus: 0
            assign has_image = false
            if block.settings.image != blank
              assign has_image = true
            endif
          -%}
          <article
            class="ctc__card{% if has_image %} ctc__card--has-image{% endif %}"
            {{ block.shopify_attributes }}
          >

            {%- comment %} Image produit / lifestyle {% endcomment %}
            {%- if has_image -%}
              <div class="ctc__card-media">
                <img
                  class="ctc__card-img"
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.review_title | default: block.settings.name | escape }}"
                  width="600"
                  height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}"
                  loading="lazy"
                >
              </div>
            {%- endif -%}

            <div class="ctc__card-body">
              {%- comment %} Titre avis {% endcomment %}
              {%- if block.settings.review_title != blank -%}
                <h3 class="ctc__review-title">{{ block.settings.review_title | escape }}</h3>
              {%- endif -%}

              {%- comment %} Étoiles {% endcomment %}
              {%- if rating > 0 -%}
                <div class="ctc__stars" aria-label="{{ rating }} étoiles sur 5">
                  {%- for i in (1..5) -%}
                    <span class="ctc__star{% if i <= rating %} ctc__star--filled{% else %} ctc__star--empty{% endif %}" aria-hidden="true">
                      <svg viewBox="0 0 16 16" fill="none">
                        {%- if i <= rating -%}
                          <path d="M8 1L10 6H15L11 9.5L12.5 14.5L8 11.5L3.5 14.5L5 9.5L1 6H6L8 1Z" fill="currentColor"/>
                        {%- else -%}
                          <path d="M8 1L10 6H15L11 9.5L12.5 14.5L8 11.5L3.5 14.5L5 9.5L1 6H6L8 1Z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        {%- endif -%}
                      </svg>
                    </span>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- comment %} Texte avis {% endcomment %}
              {%- if block.settings.text != blank -%}
                <p class="ctc__text">{{ block.settings.text | escape | truncate: 200 }}</p>
              {%- endif -%}

              {%- comment %} Auteur {% endcomment %}
              <div class="ctc__footer">
                <span class="ctc__dash" aria-hidden="true">—</span>
                <span class="ctc__author-name">{{ block.settings.name | escape }}</span>
                {%- if block.settings.verified -%}
                  <span class="ctc__verified" aria-label="Achat vérifié">
                    <svg viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <circle cx="7" cy="7" r="6" fill="currentColor"/>
                      <path d="M4.5 7L6.2 8.7L9.5 5.3" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- endif -%}
              </div>
            </div>

          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="ctc__empty">Ajoutez des blocs « Témoignage » dans l'éditeur.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Avis clients – Grille",
  "tag": "section",
  "class": "section-custom-testimonials-carousel",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "placeholder": "ex : Ce que disent nos clientes"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Elles en parlent mieux que nous"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "placeholder": "ex : Plus de 2 400 avis vérifiés"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Couleur des étoiles",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#FAFAF8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace au-dessus",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en-dessous",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image produit / photo",
          "info": "Image affichée en haut de la carte (recommandé : 600×600 ou plus)"
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo du client (optionnelle)"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Titre de l'avis",
          "default": "Très satisfaite !"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Prénom et nom",
          "default": "Marie D."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Ville (optionnelle)",
          "placeholder": "ex : Paris"
        },
        {
          "type": "select",
          "id": "rating",
          "label": "Note",
          "options": [
            { "value": "5", "label": "5 étoiles" },
            { "value": "4", "label": "4 étoiles" },
            { "value": "3", "label": "3 étoiles" },
            { "value": "2", "label": "2 étoiles" },
            { "value": "1", "label": "1 étoile" }
          ],
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte de l'avis",
          "default": "Résultats visibles dès la première semaine. Ma peau est transformée, plus lumineuse et hydratée. Je recommande les yeux fermés !"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Afficher le badge \"Achat vérifié\"",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avis clients – Grille",
      "blocks": [
        { "type": "testimonial", "settings": { "review_title": "A très bien fonctionné", "name": "Sophie L.", "rating": "5", "text": "La plupart des gens m'ont dit que je n'obtiendrais pas une grande différence, mais je l'utilise habituellement et les résultats sont incroyables.", "verified": true } },
        { "type": "testimonial", "settings": { "review_title": "J'adore ce produit.", "name": "Camille R.", "rating": "5", "text": "Il fonctionne à merveille, parfois on oublie qu'il est là. C'est tellement plus facile et pratique au quotidien.", "verified": true } },
        { "type": "testimonial", "settings": { "review_title": "Génial", "name": "Hanna F.", "rating": "5", "text": "La plupart des gens m'ont dit que c'est un appareil portable, mais je l'utilise généralement plus que tout et j'ai l'impression que c'est le meilleur investissement.", "verified": true } },
        { "type": "testimonial", "settings": { "review_title": "Très belle qualité", "name": "Nina", "rating": "4", "text": "Pour une fille de taille moyenne, c'est parfait. Bien ajusté au niveau de la ceinture, pas trop large. C'est ce que je cherchais.", "verified": true } },
        { "type": "testimonial", "settings": { "review_title": "La maman l'adore et le bébé aussi.", "name": "Keli", "rating": "5", "text": "J'ai acheté ce produit et maintenant il a un an et je l'utilise toujours. Il l'adore, et ma vie est tellement plus facile.", "verified": true } },
        { "type": "testimonial", "settings": { "review_title": "Excellent rapport qualité-prix", "name": "Cataleya", "rating": "5", "text": "On peut le laisser partout, c'est super léger et facile à transporter. Je l'ai offert à ma sœur qui l'adore aussi.", "verified": true } }
      ]
    }
  ]
}
{% endschema %}
