{% comment %}
  Custom Routine Builder – Routine beauté complémentaire
  Dawn 15.x · Vanilla JS · fetch API · Mobile-first
{% endcomment %}

{{ 'custom-routine-builder.css' | asset_url | stylesheet_tag }}

{%- assign routine_blocks = section.blocks | where: 'type', 'routine_step' -%}
{%- assign discount_pct   = section.settings.discount_percent | times: 1 -%}

<section
  class="custom-routine-builder"
  data-section-id="{{ section.id }}"
  style="
    --crb-accent:       {{ section.settings.accent_color }};
    --crb-border:       {{ section.settings.border_color }};
    --crb-checked-bg:   {{ section.settings.checked_bg }};
    --crb-btn-bg:       {{ section.settings.button_bg }};
    --crb-btn-color:    {{ section.settings.button_color }};
    --crb-discount-pct: '{{ discount_pct }}';
  "
  data-discount-pct="{{ discount_pct }}"
>
  <div class="crb__inner page-width">

    {%- comment %} ── En-tête ──────────────────────────────────── {% endcomment %}
    <div class="crb__header">
      {%- if section.settings.title != blank -%}
        <h2 class="crb__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="crb__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- if routine_blocks.size > 0 -%}

      {%- comment %} ── Grille des étapes ─────────────────────── {% endcomment %}
      <div class="crb__steps" data-crb-steps>

        {%- for block in routine_blocks -%}
          {%- assign step_product = block.settings.product -%}
          {%- if step_product != blank -%}
            {%- assign step_variant = step_product.selected_or_first_available_variant -%}
            {%- assign step_price   = step_variant.price -%}
            {%- assign step_label   = block.settings.step_label | default: step_product.title -%}

            <div
              class="crb__step"
              data-crb-step
              data-variant-id="{{ step_variant.id }}"
              data-price="{{ step_price }}"
              data-available="{{ step_variant.available }}"
              {{ block.shopify_attributes }}
            >
              {%- comment %} Checkbox ─────────────────────────── {% endcomment %}
              <label class="crb__check-wrap" aria-label="Ajouter {{ step_product.title | escape }} à la routine">
                <input
                  type="checkbox"
                  class="crb__checkbox"
                  data-crb-checkbox
                  {% if step_variant.available %}checked{% else %}disabled{% endif %}
                  value="{{ step_variant.id }}"
                >
                <span class="crb__checkmark" aria-hidden="true">
                  <svg viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <polyline points="1,5 4.5,9 11,1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </label>

              {%- comment %} Image ───────────────────────────── {% endcomment %}
              <a href="{{ step_product.url }}" class="crb__img-link" tabindex="-1" aria-hidden="true">
                {%- if step_product.featured_image -%}
                  <img
                    class="crb__img"
                    src="{{ step_product.featured_image | image_url: width: 200 }}"
                    srcset="
                      {{ step_product.featured_image | image_url: width: 120 }} 120w,
                      {{ step_product.featured_image | image_url: width: 200 }} 200w,
                      {{ step_product.featured_image | image_url: width: 300 }} 300w
                    "
                    sizes="120px"
                    alt="{{ step_product.featured_image.alt | escape | default: step_product.title | escape }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                {%- else -%}
                  <div class="crb__img crb__img--placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21,15 16,10 5,21"/>
                    </svg>
                  </div>
                {%- endif -%}
              </a>

              {%- comment %} Infos produit ───────────────────── {% endcomment %}
              <div class="crb__info">
                <span class="crb__step-label">
                  Étape {{ forloop.index }}
                  {%- if step_label != blank %} · {{ step_label | escape }}{%- endif -%}
                </span>
                <a href="{{ step_product.url }}" class="crb__product-name">
                  {{ step_product.title | escape }}
                </a>
                <div class="crb__price-wrap">
                  {%- if step_variant.compare_at_price > step_variant.price -%}
                    <span class="crb__price crb__price--sale">{{ step_variant.price | money }}</span>
                    <s class="crb__price crb__price--compare">{{ step_variant.compare_at_price | money }}</s>
                  {%- else -%}
                    <span class="crb__price">{{ step_variant.price | money }}</span>
                  {%- endif -%}
                </div>
                {%- unless step_variant.available -%}
                  <span class="crb__unavailable">Épuisé</span>
                {%- endunless -%}
              </div>

              {%- comment %} Connecteur + (sauf dernier) ─────── {% endcomment %}
              {%- unless forloop.last -%}
                <div class="crb__connector" aria-hidden="true">+</div>
              {%- endunless -%}
            </div>

          {%- endif -%}
        {%- endfor -%}

      </div>
      {%- comment %} fin steps {% endcomment %}

      {%- comment %} ── Récapitulatif & CTA ───────────────────── {% endcomment %}
      <div class="crb__summary" data-crb-summary>

        <div class="crb__prices">
          {%- if discount_pct > 0 -%}
            <div class="crb__price-line">
              <span class="crb__price-label">Prix normal</span>
              <span class="crb__price-original" data-crb-original>—</span>
            </div>
            <div class="crb__price-line crb__price-line--discount">
              <span class="crb__price-label">
                Remise routine
                <span class="crb__discount-badge">-{{ discount_pct }}%</span>
              </span>
              <span class="crb__savings" data-crb-savings>—</span>
            </div>
            <div class="crb__price-line crb__price-line--total">
              <span class="crb__price-label">Total routine</span>
              <span class="crb__price-total" data-crb-total>—</span>
            </div>
          {%- else -%}
            <div class="crb__price-line crb__price-line--total">
              <span class="crb__price-label">Total routine</span>
              <span class="crb__price-total" data-crb-total>—</span>
            </div>
          {%- endif -%}
        </div>

        <button
          class="crb__add-btn"
          data-crb-add-btn
          type="button"
          aria-live="polite"
        >
          <span class="crb__btn-label" data-crb-btn-label>
            {{ section.settings.button_label }}
          </span>
          <span class="crb__btn-spinner" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2.5"
                stroke-dasharray="28" stroke-dashoffset="10" stroke-linecap="round"/>
            </svg>
          </span>
        </button>

        <p class="crb__notice" data-crb-notice aria-live="polite"></p>

      </div>

    {%- else -%}
      {%- if request.design_mode -%}
        <p class="crb__empty">Ajoutez des étapes via les blocks dans le theme editor.</p>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

<script src="{{ 'custom-routine-builder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Routine beauté",
  "tag": "section",
  "class": "section-custom-routine-builder",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Complétez votre routine"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Des produits sélectionnés pour vous"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Ajouter la routine au panier"
    },
    {
      "type": "header",
      "content": "Remise sur la routine"
    },
    {
      "type": "range",
      "id": "discount_percent",
      "label": "Remise (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 15,
      "info": "0 = pas de remise affichée"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur des bordures",
      "default": "#e8e2da"
    },
    {
      "type": "color",
      "id": "checked_bg",
      "label": "Fond produit sélectionné",
      "default": "#fdf8f2"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Fond du bouton",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Texte du bouton",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace au-dessus",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en-dessous",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "routine_step",
      "name": "Étape de routine",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit"
        },
        {
          "type": "text",
          "id": "step_label",
          "label": "Label de l'étape",
          "placeholder": "ex : Nettoyant, Sérum, Crème…",
          "info": "Affiché sous 'Étape X'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Routine beauté"
    }
  ]
}
{% endschema %}
