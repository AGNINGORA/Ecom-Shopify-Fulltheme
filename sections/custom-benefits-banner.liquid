{% comment %}
  custom-benefits-banner.liquid
  Bénéfices produit / marque — titre centré + grille de cartes
  Dawn 15.x · Vanilla CSS uniquement (pas de JS requis)
{% endcomment %}

{{ 'custom-benefits-banner.css' | asset_url | stylesheet_tag }}

{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
{%- assign col_count = benefit_blocks.size | at_most: 6 | at_least: 2 -%}

<section
  class="section-custom-benefits-banner"
  data-section-id="{{ section.id }}"
  style="
    --cbb-padding-top:    {{ section.settings.padding_top }}px;
    --cbb-padding-bottom: {{ section.settings.padding_bottom }}px;
    --cbb-section-bg:     {{ section.settings.section_bg }};
    --cbb-card-bg:        {{ section.settings.card_bg }};
    --cbb-icon-bg:        {{ section.settings.icon_bg }};
    --cbb-accent:         {{ section.settings.accent_color }};
    --cbb-cols:           {{ col_count | at_most: 3 }};
  "
>
  <div class="cbb__inner page-width">

    {%- comment %} ── En-tête ── {% endcomment %}
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="cbb__header">
        {%- if section.settings.title != blank -%}
          <h2 class="cbb__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="cbb__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment %} ── Grille de bénéfices ── {% endcomment %}
    {%- if benefit_blocks.size > 0 -%}
      <div class="cbb__grid">

        {%- for block in benefit_blocks -%}
          <div
            class="cbb__card"
            {{ block.shopify_attributes }}
          >

            {%- comment %} Icône SVG inline {% endcomment %}
            <span class="cbb__icon" aria-hidden="true">
              {%- case block.settings.icon -%}

                {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
                  <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
                </svg>

                {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>

                {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>

                {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>

                {%- when 'check' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>

                {%- when 'flask' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 3h6v10l3.5 6.5A2 2 0 0 1 16.76 22H7.24a2 2 0 0 1-1.74-2.99L9 13V3z"/>
                  <path d="M6.5 14.5h11"/>
                </svg>

                {%- when 'drop' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                </svg>

                {%- when 'sun' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5"/>
                  <line x1="12" y1="1"  x2="12" y2="3"/>
                  <line x1="12" y1="21" x2="12" y2="23"/>
                  <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                  <line x1="1" y1="12" x2="3" y2="12"/>
                  <line x1="21" y1="12" x2="23" y2="12"/>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                  <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
                </svg>

                {%- when 'recycle' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1 4 1 10 7 10"/>
                  <polyline points="23 20 23 14 17 14"/>
                  <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
                </svg>

                {%- when 'lock' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>

                {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13" rx="1"/>
                  <path d="M16 8h4l3 5v3h-7V8z"/>
                  <circle cx="5.5"  cy="18.5" r="2.5"/>
                  <circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>

                {%- else -%}
                {%- comment %} Fallback : check {% endcomment %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>

              {%- endcase -%}
            </span>

            {%- comment %} Texte ── {% endcomment %}
            <div class="cbb__content">
              {%- if block.settings.title != blank -%}
                <p class="cbb__card-title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="cbb__card-desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}

      </div>

    {%- elsif request.design_mode -%}
      <p class="cbb__placeholder">
        Ajoutez des blocks "Bénéfice" pour remplir cette section.
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Bénéfices",
  "tag": "section",
  "class": "section-custom-benefits-banner",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Formulé pour votre peau, pas pour les marges"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Des ingrédients sélectionnés avec soin, pour des résultats visibles dès les premières semaines."
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fond de la section",
      "default": "#F7F5F2"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Fond des icônes",
      "default": "#F0EDE8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur des icônes",
      "default": "#C9A96E"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace au-dessus",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en-dessous",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Bénéfice",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "leaf",    "label": "Feuille (naturel)" },
            { "value": "shield",  "label": "Bouclier (protection)" },
            { "value": "heart",   "label": "Cœur (bien-être)" },
            { "value": "star",    "label": "Étoile (qualité)" },
            { "value": "check",   "label": "Coche (certifié)" },
            { "value": "flask",   "label": "Flacon (formule)" },
            { "value": "drop",    "label": "Goutte (hydratation)" },
            { "value": "sun",     "label": "Soleil (protection UV)" },
            { "value": "recycle", "label": "Recyclage (éco)" },
            { "value": "lock",    "label": "Cadenas (sécurité)" },
            { "value": "truck",   "label": "Livraison" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "placeholder": "ex : Sans parabène"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description courte",
          "placeholder": "ex : Formulé sans perturbateurs endocriniens, pour toute la famille."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bénéfices",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "leaf",
            "title": "100 % naturel",
            "description": "Nos formules contiennent uniquement des ingrédients d'origine naturelle, certifiés et traçables."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "shield",
            "title": "Sans parabène",
            "description": "Aucun conservateur controversé. Efficace et sûr pour toute la famille, y compris les peaux sensibles."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "flask",
            "title": "Cliniquement testé",
            "description": "Développé avec des dermatologues et testé sous contrôle médical pour des résultats prouvés."
          }
        }
      ]
    }
  ]
}
{% endschema %}
