{% comment %}
  Custom Bundle Offer – Multi-produits avec remise progressive
  Dawn 15.x · Vanilla JS · fetch API · Mobile-first
{% endcomment %}

{{ 'custom-bundle-offer.css' | asset_url | stylesheet_tag }}

{%- assign product_blocks = section.blocks | where: 'type', 'bundle_product' -%}

<section
  class="custom-bundle-offer"
  data-section-id="{{ section.id }}"
  data-discount="{{ section.settings.discount_percent }}"
  data-min-products="{{ section.settings.min_products }}"
  style="
    --cbo-accent:    {{ section.settings.accent_color }};
    --cbo-border:    {{ section.settings.border_color }};
    --cbo-btn-bg:    {{ section.settings.button_bg }};
    --cbo-btn-color: {{ section.settings.button_color }};
    padding-top:     {{ section.settings.padding_top }}px;
    padding-bottom:  {{ section.settings.padding_bottom }}px;
  "
>
  <div class="cbo__inner page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="cbo__heading">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="cbo__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- if product_blocks.size > 0 -%}

      {%- comment %} ══════════════════════════════
          GRILLE PRODUITS
      ══════════════════════════════ {% endcomment %}
      <div class="cbo__products" data-cbo-products>
        {%- for block in product_blocks -%}
          {%- assign bp = block.settings.product -%}
          {%- if bp != blank -%}
            {%- assign bp_v = bp.selected_or_first_available_variant -%}

            <div
              class="cbo__product-card"
              data-cbo-card
              data-product-id="{{ bp.id }}"
              data-variant-id="{{ bp_v.id }}"
              data-price="{{ bp_v.price }}"
              data-available="{{ bp_v.available }}"
              {{ block.shopify_attributes }}
            >
              {%- comment %} Checkbox ─────────────────── {% endcomment %}
              <label class="cbo__check-wrap">
                <input
                  type="checkbox"
                  class="cbo__check"
                  data-cbo-check
                  checked
                >
                <span class="cbo__checkmark">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
              </label>

              {%- comment %} Image ────────────────────── {% endcomment %}
              <a class="cbo__card-img-link" href="{{ bp.url }}">
                {%- if bp.featured_image -%}
                  <img
                    class="cbo__card-img"
                    src="{{ bp.featured_image | image_url: width: 200 }}"
                    alt="{{ bp.featured_image.alt | escape | default: bp.title | escape }}"
                    loading="lazy"
                    width="200"
                    height="200"
                    data-cbo-img
                  >
                {%- else -%}
                  <div class="cbo__card-img-placeholder"></div>
                {%- endif -%}
              </a>

              {%- comment %} Infos ────────────────────── {% endcomment %}
              <div class="cbo__card-info">
                <a class="cbo__card-title" href="{{ bp.url }}">{{ bp.title | truncate: 50 }}</a>

                {%- comment %} Sélecteur de variante ──── {% endcomment %}
                {%- if bp.variants.size > 1 -%}
                  <select class="cbo__card-variant" data-cbo-variant-select>
                    {%- for v in bp.variants -%}
                      <option
                        value="{{ v.id }}"
                        data-price="{{ v.price }}"
                        data-available="{{ v.available }}"
                        {%- if v.featured_media %} data-img="{{ v.featured_media | image_url: width: 200 }}"{% endif %}
                        {% if v == bp_v %}selected{% endif %}
                      >
                        {{ v.title }}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}

                <span class="cbo__card-price" data-cbo-card-price>{{ bp_v.price | money }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment %} ══════════════════════════════
          RÉSUMÉ PRIX + CTA
      ══════════════════════════════ {% endcomment %}
      <div class="cbo__summary" data-cbo-summary>
        <div class="cbo__summary-row">
          <span class="cbo__summary-label">Prix total :</span>
          <s class="cbo__summary-original" data-cbo-original hidden></s>
          <span class="cbo__summary-discounted" data-cbo-discounted></span>
        </div>
        <p class="cbo__savings-line" data-cbo-savings></p>

        <button
          class="cbo__add-btn"
          data-cbo-add-btn
          type="button"
        >
          <span class="cbo__btn-label" data-cbo-btn-label>
            {{ section.settings.button_label }}
          </span>
          <span class="cbo__btn-spinner" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="9"
                stroke="currentColor" stroke-width="2.5"
                stroke-dasharray="28" stroke-dashoffset="10"
                stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <p class="cbo__notice" data-cbo-notice aria-live="polite"></p>
      </div>

    {%- else -%}
      {%- if request.design_mode -%}
        <p class="cbo__empty">Ajoutez des blocs « Produit du bundle » pour composer votre offre.</p>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

<script src="{{ 'custom-bundle-offer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Offre bundle",
  "tag": "section",
  "class": "section-custom-bundle-offer",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Offres spéciales"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Plus vous achetez, plus vous économisez"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Ajouter le lot au panier"
    },
    {
      "type": "range",
      "id": "discount_percent",
      "label": "Remise bundle (%)",
      "info": "Remise appliquée quand le nombre minimum de produits est coché",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "min_products",
      "label": "Produits minimum pour la remise",
      "info": "Nombre de produits cochés nécessaire pour activer la remise",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur des bordures",
      "default": "#e8e2da"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Fond du bouton",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Texte du bouton",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace au-dessus",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en-dessous",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "bundle_product",
      "name": "Produit du bundle",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Offre bundle"
    }
  ]
}
{% endschema %}
